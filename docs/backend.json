
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the CFO Fitness app, storing core identity, health summaries, and account status.",
      "properties": {
        "id": {
          "type": "string"
        },
        "visceralFatPoints": {
          "type": "number"
        },
        "dailyProteinG": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "isAnonymous": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "visceralFatPoints",
        "dailyProteinG",
        "createdAt",
        "isAnonymous"
      ]
    },
    "UserPreferences": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserPreferences",
      "type": "object",
      "description": "Stores user-specific settings like training schedule, equipment, and goals.",
      "properties": {
        "weeklySchedule": {
          "type": "string",
          "description": "JSON string representing the weekly workout schedule."
        },
        "equipment": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of home equipment assets."
        },
        "targets": {
          "type": "object",
          "properties": {
            "proteinGoal": { "type": "number" },
            "fatPointsGoal": { "type": "number" }
          }
        }
      }
    },
    "Log": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Log",
      "type": "object",
      "description": "Records various user activities and health data.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "metrics": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "timestamp", "category", "content", "metrics"]
    },
    "ChatSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChatSession",
      "type": "object",
      "description": "Stores the conversational memory between a user and the AI coach.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "messages": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "createdAt", "messages"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Primary profile info."
        }
      },
      {
        "path": "/users/{userId}/preferences/settings",
        "definition": {
          "entityName": "UserPreferences",
          "schema": { "$ref": "#/backend/entities/UserPreferences" },
          "description": "Stores schedule and equipment context."
        }
      },
      {
        "path": "/users/{userId}/logs/{logId}",
        "definition": {
          "entityName": "Log",
          "schema": { "$ref": "#/backend/entities/Log" },
          "description": "Activity logs."
        }
      }
    ]
  }
}
