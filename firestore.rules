
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /preferences/{prefId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      match /logs/{logId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      match /food_log/{entryId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      match /exercise_log/{entryId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      match /fast_log/{entryId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      match /chat_sessions/{chatId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
      match /shared_data/{entryId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    // Publicly shareable meal snapshots (link-as-bearer-token). The random
    // doc ID is the unguessable token. A single doc is readable by anyone with
    // the link until it is revoked; enumeration (list) is disabled. All writes
    // go through trusted server actions on the Admin SDK, which bypass rules —
    // so direct client writes are denied here.
    match /shared_meals/{shareId} {
      allow get: if resource.data.revoked != true;
      allow list, create, update, delete: if false;
    }
  }
}
