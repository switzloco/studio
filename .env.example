# Copy this file to .env.local and fill in your values.

# ── AI / Genkit ─────────────────────────────────────────────────────────────
# Required: Google Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_GENAI_API_KEY=

# ── Research Tools ───────────────────────────────────────────────────────────
# Optional: USDA FoodData Central API key for macro lookups.
# Falls back to DEMO_KEY (100 req/hr) if unset.
# Get a free key: https://fdc.nal.usda.gov/api-guide.html
USDA_FOOD_API_KEY=DEMO_KEY

# Required for web search: Serper.dev API key.
# Free tier: 2,500 searches/month — https://serper.dev
SERPER_API_KEY=

# ── Firebase ─────────────────────────────────────────────────────────────────
# These values come from your Firebase project console.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Fitbit OAuth ─────────────────────────────────────────────────────────────
# Optional: enables device-verified steps/HRV/sleep data.
# Create an app at https://dev.fitbit.com/apps/new (Personal type, OAuth 2.0)
NEXT_PUBLIC_FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# ── Cron / Background Jobs ────────────────────────────────────────────────────
# Required for the Fitbit background-sync cron endpoint (/api/cron/fitbit-sync).
# Must match the ?secret= query param configured in Cloud Scheduler.
# Generate with: openssl rand -hex 32
# In Firebase App Hosting, store via Secret Manager:
#   firebase apphosting:secrets:set CRON_SECRET
# Then reference it in apphosting.yaml under the env section.
CRON_SECRET=
